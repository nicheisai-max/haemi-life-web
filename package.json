{
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "tsx scripts/safe-dev.ts",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "test:backend": "npm --prefix backend run test:backend",
    "test:frontend": "npm --prefix frontend run test:frontend",
    "test:e2e": "npm --prefix e2e run test",
    "test:auth": "npm run test:backend && npm run test:frontend && npm run test:e2e && powershell -Command \"Get-NetTCPConnection -LocalPort 5173,5000 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "prepare": "node -e \"if(process.env.CI !== 'true') require('child_process').execSync('npx husky', {stdio: 'inherit'})\"",
    "safe-dev": "tsx scripts/safe-dev.ts",
    "demo": "tsx scripts/safe-dev.ts",
    "type-check": "npm --prefix backend run typecheck && npm --prefix frontend run typecheck",
    "migration:guard": "tsx scripts/migration-guard.ts",
    "schema:guard": "tsx scripts/schema-guard.ts",
    "identity:guard": "tsx scripts/identity-guard.ts",
    "branch:guard": "tsx scripts/branch-guard.ts",
    "lint": "npm --prefix backend run lint && npm --prefix frontend run lint",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "test:ci": "npm run test:backend",
    "db:health": "npm --prefix backend run db:health",
    "safe-push": "powershell -ExecutionPolicy Bypass -File scripts/safe-push.ps1",
    "sync": "tsx scripts/repo-hygiene.ts"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint -c backend/eslint.config.mjs --max-warnings=0"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint -c frontend/eslint.config.js --max-warnings=0"
    ]
  }
}
