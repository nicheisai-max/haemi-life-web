{
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "dependencies": {
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "tsx scripts/safe-dev.ts",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "test:backend": "npm --prefix backend run test:backend",
    "test:frontend": "npm --prefix frontend run test:frontend",
    "test:e2e": "npm --prefix e2e run test",
    "test:auth": "npm run test:backend && npm run test:frontend && npm run test:e2e && powershell -Command \"Get-NetTCPConnection -LocalPort 5173,5000 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "prepare": "node -e \"if(!process.env.CI && !process.env.GITHUB_ACTIONS) require('child_process').execSync('npx husky', {stdio: 'inherit'})\"",
    "safe-dev": "tsx scripts/safe-dev.ts",
    "demo": "tsx scripts/safe-dev.ts",
    "type-check": "npm --prefix backend run typecheck && npm --prefix frontend run typecheck",
    "migration:guard": "node scripts/migration_guard.js",
    "branch:guard": "node scripts/branch_guard.js",
    "lint": "npm --prefix backend run lint && npm --prefix frontend run lint",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "test:ci": "npm run test:backend",
    "verify": "node scripts/verifyCommitIntegrity.js",
    "sandbox": "tsx scripts/new-sandbox.ts",
    "orchestrate": "tsx scripts/orchestrator.ts",
    "ai-review": "tsx scripts/ai-self-review.ts",
    "quality-gate": "tsx scripts/ai-self-review.ts --enforce",
    "sync": "git checkout main && git fetch origin --prune && git reset --hard origin/main && powershell -Command \"git branch --list 'ai/sandbox-*' | ForEach-Object { git branch -D $_.Trim() }\" && git remote prune origin && git branch -a && git status",
    "prepush-check": "tsx scripts/prepush-check.ts"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint -c backend/eslint.config.mjs --max-warnings=0"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint -c frontend/eslint.config.js --max-warnings=0"
    ]
  }
}