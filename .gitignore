# =============================================================================
# HAEMI LIFE — ENTERPRISE .GITIGNORE
# Policy: Zero-tolerance for secrets, build artifacts, temp files, and logs.
# Last updated: 2026-04-06 (Institutional Lockdown v10.6)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────────────────────────────────────────
node_modules/

# Root package-lock.json is the single source of truth for the monorepo.
# Workspace-level lockfiles must never be committed.
backend/package-lock.json
frontend/package-lock.json

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & SECRETS (NEVER COMMIT)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
TEST_CREDENTIALS.md

# ─────────────────────────────────────────────────────────────────────────────
# BUILD OUTPUTS
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# LOGS — No log files in the repository
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ─────────────────────────────────────────────────────────────────────────────
# TEMPORARY & DEBUG FILES — Critical for cleanliness (Rule 5 & 10)
# ─────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
tmp/
dist/tmp/

# CI / AI pipeline temporary artifacts
.ci-stats-bundle.json
lint_output.txt
lint_results.json
backend_lint.txt
test_output.txt
test_detailed.txt
debug_output.txt
eslint_out.json

# Frontend debug artifacts
frontend/build_verify.txt
frontend/lint_errors.txt
frontend/tsc_errors.txt

# Bundle analysis
bundle-report.html
*.bundle

# Scripts temp
scripts/tmp-*
scripts/temp-*
scripts/devops-runner*.ts

# ─────────────────────────────────────────────────────────────────────────────
# COVERAGE & TEST OUTPUTS
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─────────────────────────────────────────────────────────────────────────────
# CACHE DIRECTORIES
# ─────────────────────────────────────────────────────────────────────────────
.cache/
.turbo/
.next/
.nuxt/

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE & UPLOAD ARTIFACTS (Rule 5 — Zero-User Data Policy)
# ─────────────────────────────────────────────────────────────────────────────
*.sql
*.dump
/backups/
/backend/backups/
/database_backups/
*.backup.sql
/backend/uploads/
/backend/data/
/backend/temp/
/common/uploads/

# ─────────────────────────────────────────────────────────────────────────────
# LARGE / BINARY FILES (Rule 9)
# ─────────────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tar.bz2
*.rar

# ─────────────────────────────────────────────────────────────────────────────
# AI / AGENT GENERATED FILES (Zero-Pollution Policy)
# ─────────────────────────────────────────────────────────────────────────────
.ai-system/
.agent/
ai-rules/
ai/
CLAUDE.md
Haemi_Forensic_Audit.js
*.analysis.json
*.ai-log
*.ai-report.md

# ─────────────────────────────────────────────────────────────────────────────
# EDITOR & IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.idea/

# ─────────────────────────────────────────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# TEMPORARY FRONTEND DIRECTORIES
# ─────────────────────────────────────────────────────────────────────────────
frontend_trash/
frontend_backup/

# ─────────────────────────────────────────────────────────────────────────────
# PROTECTED — Ensure these directories are always tracked
# ─────────────────────────────────────────────────────────────────────────────
!backend/db/
!backend/scripts/

# ─────────────────────────────────────────────────────────────────────────────
# HAEMI LIFE: AUTOMATIC LOCKDOWN (v10.6)
# ─────────────────────────────────────────────────────────────────────────────
# Test Artifacts (Screenshots, Videos, Reports)
e2e/test-results/
e2e/playwright-report/
playwright-report/
test-results/

# Institutional Reports & Scaffolding
tmp/
temp/
backend/*.txt
frontend/*.txt
*.txt
!*.md
!LICENSE

# Force ignore all uploads and diagnostic scripts
backend/uploads/**/*
backend/uploads/temp/**/*
backend/*.ts
!backend/src/**/*.ts
backend/*.js
!backend/src/**/*.js
*.tsbuildinfo
**/temp_attachments/**/*
**/_quarantine/**/*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────────────────────
# CLAUDE CODE LOCAL STATE (CLI tooling — never commit)
# ─────────────────────────────────────────────────────────────────────────────
# .claude/ holds Claude Code's per-project config, worktrees, and local settings.
# All AI-specific metadata is now strictly ignored to prevent tool contention.
.claude/
