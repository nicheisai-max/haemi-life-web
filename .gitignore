# =============================================================================
# HAEMI LIFE — ENTERPRISE .GITIGNORE
# Policy: Zero-tolerance for secrets, build artifacts, temp files, and logs.
# Last updated: 2026-03-18
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────────────────────────────────────────
node_modules/

# Root package-lock.json is the single source of truth for the monorepo.
# Workspace-level lockfiles must never be committed.
backend/package-lock.json
frontend/package-lock.json

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & SECRETS (NEVER COMMIT)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
TEST_CREDENTIALS.md

# ─────────────────────────────────────────────────────────────────────────────
# BUILD OUTPUTS
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# LOGS — No log files in the repository
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ─────────────────────────────────────────────────────────────────────────────
# TEMPORARY & DEBUG FILES — Critical for cleanliness (Rule 5 & 10)
# ─────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
tmp/
dist/tmp/

# CI / AI pipeline temporary artifacts
.ci-stats-bundle.json
lint_output.txt
lint_results.json
backend_lint.txt
test_output.txt
test_detailed.txt
debug_output.txt
eslint_out.json

# Frontend debug artifacts
frontend/build_verify.txt
frontend/lint_errors.txt
frontend/tsc_errors.txt

# Bundle analysis
bundle-report.html
*.bundle

# Scripts temp
scripts/tmp-*
scripts/temp-*
scripts/devops-runner*.ts

# ─────────────────────────────────────────────────────────────────────────────
# COVERAGE & TEST OUTPUTS
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─────────────────────────────────────────────────────────────────────────────
# CACHE DIRECTORIES
# ─────────────────────────────────────────────────────────────────────────────
.cache/
.turbo/
.next/
.nuxt/

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE ARTIFACTS (Rule 5 — no backups committed)
# ─────────────────────────────────────────────────────────────────────────────
*.sql
*.dump
/backups/
/backend/backups/
/database_backups/
backend/uploads/

# ─────────────────────────────────────────────────────────────────────────────
# LARGE / BINARY FILES (Rule 9)
# ─────────────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tar.bz2
*.rar

# ─────────────────────────────────────────────────────────────────────────────
# AI / ANALYSIS ARTIFACTS
# ─────────────────────────────────────────────────────────────────────────────
.ai-system/
*.analysis.json
*.ai-log
*.ai-report.md

# ─────────────────────────────────────────────────────────────────────────────
# EDITOR & IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.idea/

# ─────────────────────────────────────────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# TEMPORARY FRONTEND DIRECTORIES
# ─────────────────────────────────────────────────────────────────────────────
frontend_trash/
frontend_backup/

# ─────────────────────────────────────────────────────────────────────────────
# PROTECTED — Ensure these directories are always tracked
# ─────────────────────────────────────────────────────────────────────────────
!backend/db/
!backend/scripts/

# ─────────────────────────────────────────────────────────────────────────────
# ADDITIONAL ZERO-TRUST HARDENING
# ─────────────────────────────────────────────────────────────────────────────
# Test artifacts
e2e/playwright-report/
e2e/test-results/

# Logs
backend/full_lint_errors.txt
backend/lint_failures.txt
backend/lint_output.txt
frontend/tsc_errors.txt
frontend/lint_errors.txt
*.txt

# Media artifacts
*.png
*.webm
*.mp4

# Temp
temp/
