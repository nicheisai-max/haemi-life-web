#!/bin/sh

echo "Running enterprise pre-push guardrails..."
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ]; then
  echo "PUSH BLOCKED: main branch is protected. Use sandbox branches and pull requests."
  exit 1
fi

# Minimal push checks, delegating core validation to CI
npm run branch:guard || { echo "Branch Protection Failed"; exit 1; }
