#!/bin/sh


echo "Running enterprise pre-commit guardrails..."
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ]; then
  echo "ERROR: Direct commits to the main branch are forbidden. Use sandbox branches."
  exit 1
fi

WORKTREE_COUNT=$(git worktree list | wc -l)

if [ "$WORKTREE_COUNT" -gt 1 ]; then
  echo "❌ Enterprise policy: AI worktrees are not allowed."
  echo "Remove additional worktrees before committing."
  git worktree list
  exit 1
fi

npm run branch:guard || { echo "Branch Protection Failed"; exit 1; }
npm run migration:guard || { echo "Migration Safety Guard Failed"; exit 1; }

npx lint-staged || { echo "Lint Staged Failed"; exit 1; }

npm run type-check || { echo "Type Check Failed"; exit 1; }
npm run lint --max-warnings=0 || { echo "Linting Failed"; exit 1; }
npm run build || { echo "Build Failed"; exit 1; }
