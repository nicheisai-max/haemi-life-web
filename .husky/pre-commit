#!/bin/sh

# ─────────────────────────────────────────────────────────────────────────────
# HAEMI LIFE — HUSKY PRE-COMMIT HOOK
# Enterprise pre-commit guardrails (Rule 1, 5, 9)
# ─────────────────────────────────────────────────────────────────────────────

echo "🛡  Haemi Life — Enterprise Pre-commit Guardrails"
echo "─────────────────────────────────────────────────"

# Guard 1: Branch policy enforcement (Rule 1 — sandbox development model)
echo "  [1/3] Branch policy check..."
node scripts/branch_guard.js --commit || exit 1

# Guard 2: Large file scan (Rule 9 — prevent large file commits)
echo "  [2/3] Large file & forbidden pattern check..."
node scripts/large-file-guard.js || exit 1

# Guard 3: Identity policy enforcement (Canonical user_id)
echo "  [3/4] Identity policy check..."
node scripts/identity_guard.js || exit 1

# Guard 4: Lint staged files (code quality)
echo "  [4/4] Lint staged files..."
npx lint-staged || { echo "❌ Lint Staged Failed"; exit 1; }

echo "✅ All pre-commit guardrails passed."
